from discord.ext import commands
import discord

from utils.pokemon_db import get_balls

class PokemonBalls(commands.Cog):

    def __init__(self, bot):
        self.bot = bot

    @commands.command(name="balls")
    async def balls(self, ctx):

        balls = get_balls(ctx.author.id)

        embed = discord.Embed(
            title="🎾 Your Poké Balls",
            color=0x57F287
        )

        embed.add_field(
            name="⚪ Poké Ball",
            value=str(balls.get("pokeball", 0)),
            inline=True
        )

        embed.add_field(
            name="🟡 Ultra Ball",
            value=str(balls.get("ultraball", 0)),
            inline=True
        )

        embed.add_field(
            name="🟣 Master Ball",
            value=str(balls.get("masterball", 0)),
            inline=True
        )

        await ctx.send(embed=embed)

async def setup(bot):
    await bot.add_cog(PokemonBalls(bot))
